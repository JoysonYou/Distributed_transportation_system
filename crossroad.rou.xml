<routes>
    <!-- 
        vType定义了车辆类型.
        id: 类型的唯一标识.
        accel: 最大加速度 (m/s^2).
        decel: 最大减速度 (m/s^2).
        sigma: 驾驶员的反应不确定性 (0-1), 0表示完美驾驶.
        length: 车辆长度 (m).
        minGap: 与前车的最小距离 (m).
        maxSpeed: 最大速度 (m/s).
        carFollowModel: 跟驰模型 (e.g., IDM, Krauss).
        laneChangeModel: 变道模型.
    -->
    <vType id="autonomous_car" accel="3.5" decel="5.5" sigma="0.2" length="5" minGap="2.0" maxSpeed="25" carFollowModel="IDM" laneChangeModel="LC2013" color="blue"/>
    <vType id="standard_car" accel="2.5" decel="4.5" sigma="0.5" length="5" minGap="2.5" maxSpeed="20" carFollowModel="Krauss" laneChangeModel="LC2013" color="red"/>
    
    <!-- New Vehicle Types for specific behaviors -->
    <vType id="type_straight" accel="3.0" decel="4.5" sigma="0.5" length="5" minGap="2.5" maxSpeed="22" carFollowModel="Krauss" laneChangeModel="LC2013" color="0,255,0"/>
    <vType id="type_left" accel="3.0" decel="4.5" sigma="0.5" length="4.5" minGap="2.5" maxSpeed="18" carFollowModel="Krauss" laneChangeModel="LC2013" color="255,165,0"/>
    <vType id="type_right" accel="3.0" decel="4.5" sigma="0.5" length="4.5" minGap="2.5" maxSpeed="15" carFollowModel="Krauss" laneChangeModel="LC2013" color="255,0,255"/>

    <!-- Routes -->
    <route id="W_E" edges="W_in E_out" />
    <route id="W_N" edges="W_in N_out" />
    <route id="W_S" edges="W_in S_out" />

    <route id="E_W" edges="E_in W_out" />
    <route id="E_N" edges="E_in N_out" />
    <route id="E_S" edges="E_in S_out" />

    <route id="N_S" edges="N_in S_out" />
    <route id="N_E" edges="N_in E_out" />
    <route id="N_W" edges="N_in W_out" />

    <route id="S_N" edges="S_in N_out" />
    <route id="S_E" edges="S_in E_out" />
    <route id="S_W" edges="S_in W_out" />

    <!-- 
        Flows have been removed to allow fixed route generation via Python script.
    -->
</routes>