<routes>
    <!-- 
        vType定义了车辆类型.
        id: 类型的唯一标识.
        accel: 最大加速度 (m/s^2).
        decel: 最大减速度 (m/s^2).
        sigma: 驾驶员的反应不确定性 (0-1), 0表示完美驾驶.
        length: 车辆长度 (m).
        minGap: 与前车的最小距离 (m).
        maxSpeed: 最大速度 (m/s).
        carFollowModel: 跟驰模型 (e.g., IDM, Krauss).
        laneChangeModel: 变道模型.
    -->
    <vType id="connected_car" accel="3.0" decel="4.5" sigma="0" length="5" minGap="2.5" maxSpeed="20" carFollowModel="Krauss" laneChangeModel="LC2013" color="yellow"/>

    <!-- Routes -->
    <route id="W_E" edges="W_in E_out" />
    <route id="W_N" edges="W_in N_out" />
    <route id="W_S" edges="W_in S_out" />

    <route id="E_W" edges="E_in W_out" />
    <route id="E_N" edges="E_in N_out" />
    <route id="E_S" edges="E_in S_out" />

    <route id="N_S" edges="N_in S_out" />
    <route id="N_E" edges="N_in E_out" />
    <route id="N_W" edges="N_in W_out" />

    <route id="S_N" edges="S_in N_out" />
    <route id="S_E" edges="S_in E_out" />
    <route id="S_W" edges="S_in W_out" />

</routes>